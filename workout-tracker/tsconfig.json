{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "outDir": "./dist",
    "rootDir": ".",
    "sourceMap": true
  },
  "include": ["src", "vite-env.d.ts"],
  "exclude": ["node_modules", "dist", "e2e"]
}
